{
  "name": "douyin-downloader",
  "version": "1.1.0",
  "description": "抖音视频无水印下载器",
  "main": "server.js",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "build-win": "pkg . --targets node18-win-x64 --output douyin-downloader.exe",
    "build-mac": "pkg . --targets node18-macos-x64 --output douyin-downloader-mac"
  },
  "dependencies": {
    "@larksuite/cli": "^1.0.4",
    "axios": "^0.27.2",
    "express": "^4.21.0",
    "playwright": "^1.59.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "uuid": "^10.0.0"
  },
  "bin": "server.js",
  "pkg": {
    "assets": [
      "public/**/*",
      "lib/**/*.js"
    ],
    "targets": [
      "node18-win-x64",
      "node18-macos-x64"
    ]
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
